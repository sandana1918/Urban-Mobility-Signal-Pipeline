      "datasource": { "type": "grafana-bigquery-datasource", "uid": "mobility_bigquery" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "grafana-bigquery-datasource", "uid": "mobility_bigquery" },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT SAFE_DIVIDE(SUM(revenue), SUM(trips)) AS rpt FROM `${bq_dataset}.vw_daily_kpis`"
