# Copy this file to .env and fill in real values. .env is gitignored.

# --- Google Cloud / BigQuery ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_PATH=./secrets/gcp-key.json
BQ_DATASET=urban_mobility_signal_pipeline
BQ_LOCATION=US

# --- GenAI backend (the genai stage uses whichever key is set, preferring Groq) ---
# Groq: free, no card required -> https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini: fallback if GROQ_API_KEY is unset (needs paid/prepaid billing in some regions)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=admin
